<Shell
    x:Class="RoyalBakeryGrn.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:RoyalBakeryGrn.Pages;assembly=RoyalBakeryGrn"
    FlyoutBehavior="Locked"
    FlyoutBackgroundColor="#26A69A"
    FlyoutWidth="220">

    <Shell.Resources>
        <Style TargetType="Label" x:Key="FlyoutItemLabelStyle">
            <Setter Property="FontFamily" Value="PoppinsRegular"/>
            <Setter Property="TextColor" Value="White"/>
            <Setter Property="Padding" Value="20,10"/>
        </Style>
    </Shell.Resources>

    <!-- Home -->
    <FlyoutItem Title="🏠 Home" >
        <ShellContent ContentTemplate="{DataTemplate pages:MainPage}" Route="MainPage" />
    </FlyoutItem>

    <!-- Add GRN -->
    <FlyoutItem Title="📝 Add GRN">
        <ShellContent ContentTemplate="{DataTemplate pages:AddGRN}" Route="AddGRN" />
    </FlyoutItem>

    <!-- Adjust GRN -->
    <FlyoutItem Title="⚙️ Adjust GRN" >
        <ShellContent ContentTemplate="{DataTemplate pages:AdjustmentRequestsListPage}" Route="AdjustGRN" />
    </FlyoutItem>

    <!-- Stock Manage -->
    <FlyoutItem Title="📦 Stock Manage">
        <ShellContent ContentTemplate="{DataTemplate pages:ClearancePage}" Route="StockManagePage" />
    </FlyoutItem>

    <!-- Settings -->
    <FlyoutItem Title="⚙ Settings">
        <ShellContent ContentTemplate="{DataTemplate pages:SettingsPage}" Route="SettingsPage" />
    </FlyoutItem>

</Shell>
