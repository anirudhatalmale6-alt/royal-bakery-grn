<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="RoyalBakeryGrn.Pages.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#1A1A1A"
    Shell.NavBarIsVisible="False"
    NavigationPage.HasNavigationBar="False"
    Title="Login">

    <Grid HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand">
        <ScrollView HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand">
            <VerticalStackLayout VerticalOptions="CenterAndExpand" HorizontalOptions="CenterAndExpand"
                                 Padding="40" Spacing="16" MaximumWidthRequest="420">

                <Label Text="Royal Bakery GRN"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center"
                       HorizontalOptions="Center"/>

                <Label Text="Goods Received Notes"
                       FontSize="15"
                       TextColor="#999999"
                       HorizontalTextAlignment="Center"
                       HorizontalOptions="Center"/>

                <BoxView HeightRequest="1" Color="#444444" Margin="0,8"/>

                <!-- Username -->
                <Label Text="Username" FontSize="14" TextColor="#AAAAAA"/>
                <Entry x:Name="UsernameEntry"
                       Placeholder="Enter username"
                       PlaceholderColor="#666666"
                       TextColor="White"
                       BackgroundColor="#2A2A2A"
                       FontSize="16"
                       Keyboard="Default"
                       HorizontalOptions="FillAndExpand"/>

                <!-- Password -->
                <Label Text="Password" FontSize="14" TextColor="#AAAAAA"/>
                <Entry x:Name="PasswordEntry"
                       Placeholder="Enter password"
                       PlaceholderColor="#666666"
                       TextColor="White"
                       BackgroundColor="#2A2A2A"
                       FontSize="16"
                       IsPassword="True"
                       HorizontalOptions="FillAndExpand"
                       Completed="Login_Clicked"/>

                <!-- Error message -->
                <Label x:Name="ErrorLabel"
                       Text=""
                       TextColor="OrangeRed"
                       FontSize="13"
                       HorizontalTextAlignment="Center"
                       IsVisible="False"/>

                <!-- Login Button -->
                <Button x:Name="LoginBtn"
                        Text="Login"
                        BackgroundColor="#4CAF50"
                        TextColor="White"
                        FontSize="18"
                        FontAttributes="Bold"
                        HeightRequest="52"
                        CornerRadius="10"
                        HorizontalOptions="FillAndExpand"
                        Clicked="Login_Clicked"/>

                <!-- Settings link -->
                <Label Text="API Settings"
                       FontSize="13"
                       TextColor="#888888"
                       HorizontalTextAlignment="Center"
                       TextDecorations="Underline">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Settings_Tapped"/>
                    </Label.GestureRecognizers>
                </Label>

                <Label Text="Powered by EzyCode"
                       FontSize="10"
                       TextColor="#555555"
                       HorizontalTextAlignment="Center"
                       Margin="0,20,0,0"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
