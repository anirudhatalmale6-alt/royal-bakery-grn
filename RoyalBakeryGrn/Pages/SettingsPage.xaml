<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RoyalBakeryGrn.Pages.SettingsPage"
             Title="Settings"
             BackgroundColor="#F5F5F5">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Frame BackgroundColor="White" CornerRadius="10" Padding="20" HasShadow="True">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Server Connection"
                           FontSize="20" FontFamily="PoppinsBold" TextColor="#212121"/>

                    <Label Text="Enter the IP address of the PC running the API (e.g., 192.168.1.100:5000)"
                           FontSize="13" TextColor="#616161"/>

                    <Entry x:Name="ApiUrlEntry"
                           Placeholder="e.g. http://192.168.1.100:5000"
                           FontSize="16"
                           Keyboard="Url"/>

                    <Button Text="Save &amp; Test Connection"
                            BackgroundColor="#26A69A"
                            TextColor="White"
                            FontFamily="PoppinsBold"
                            CornerRadius="8"
                            Clicked="SaveAndTest_Clicked"/>

                    <Label x:Name="StatusLabel"
                           FontSize="14"
                           TextColor="#616161"
                           IsVisible="False"/>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
