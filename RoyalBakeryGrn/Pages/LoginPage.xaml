<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="RoyalBakeryGrn.Pages.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#1A1A1A"
    Shell.NavBarIsVisible="False"
    NavigationPage.HasNavigationBar="False"
    Title="Login">

    <Grid RowDefinitions="*,Auto,*" Padding="0">

        <!-- Centered card -->
        <Frame Grid.Row="1"
               BackgroundColor="#242424"
               BorderColor="#333333"
               CornerRadius="16"
               Padding="28,24"
               HasShadow="False"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               WidthRequest="360">

            <VerticalStackLayout Spacing="14" HorizontalOptions="FillAndExpand">

                <!-- Logo area -->
                <Label Text="🍞"
                       FontSize="40"
                       HorizontalTextAlignment="Center"
                       HorizontalOptions="Center"/>

                <Label Text="The Royal Bakery"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center"/>

                <Label Text="Goods Received Notes"
                       FontSize="13"
                       TextColor="#888888"
                       HorizontalTextAlignment="Center"
                       Margin="0,0,0,4"/>

                <!-- Username -->
                <Grid RowDefinitions="Auto,Auto" RowSpacing="4">
                    <Label Text="Username" FontSize="12" TextColor="#AAAAAA" Grid.Row="0"/>
                    <Border Grid.Row="1" StrokeShape="RoundRectangle 8" Stroke="#444444" BackgroundColor="#2A2A2A" Padding="0">
                        <Entry x:Name="UsernameEntry"
                               Placeholder="Enter username"
                               PlaceholderColor="#666666"
                               TextColor="White"
                               BackgroundColor="Transparent"
                               FontSize="15"
                               Keyboard="Default"
                               HorizontalOptions="FillAndExpand"
                               HeightRequest="44"/>
                    </Border>
                </Grid>

                <!-- Password -->
                <Grid RowDefinitions="Auto,Auto" RowSpacing="4">
                    <Label Text="Password" FontSize="12" TextColor="#AAAAAA" Grid.Row="0"/>
                    <Border Grid.Row="1" StrokeShape="RoundRectangle 8" Stroke="#444444" BackgroundColor="#2A2A2A" Padding="0">
                        <Entry x:Name="PasswordEntry"
                               Placeholder="Enter password"
                               PlaceholderColor="#666666"
                               TextColor="White"
                               BackgroundColor="Transparent"
                               FontSize="15"
                               IsPassword="True"
                               HorizontalOptions="FillAndExpand"
                               HeightRequest="44"
                               Completed="Login_Clicked"/>
                    </Border>
                </Grid>

                <!-- Error message -->
                <Label x:Name="ErrorLabel"
                       Text=""
                       TextColor="#FF5252"
                       FontSize="12"
                       HorizontalTextAlignment="Center"
                       IsVisible="False"/>

                <!-- Login Button -->
                <Button x:Name="LoginBtn"
                        Text="LOGIN"
                        BackgroundColor="#4CAF50"
                        TextColor="White"
                        FontSize="16"
                        FontAttributes="Bold"
                        HeightRequest="48"
                        CornerRadius="8"
                        HorizontalOptions="FillAndExpand"
                        Clicked="Login_Clicked"
                        Margin="0,4,0,0"/>

                <!-- Settings link -->
                <Label Text="⚙ API Settings"
                       FontSize="12"
                       TextColor="#777777"
                       HorizontalTextAlignment="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Settings_Tapped"/>
                    </Label.GestureRecognizers>
                </Label>

            </VerticalStackLayout>
        </Frame>

        <!-- Footer -->
        <Label Grid.Row="2"
               Text="Powered by EzyCode"
               FontSize="10"
               TextColor="#444444"
               HorizontalTextAlignment="Center"
               VerticalOptions="End"
               Margin="0,0,0,12"/>
    </Grid>
</ContentPage>
