<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="RoyalBakeryGrn.Pages.ClearancePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#F5F5F5">

    <ScrollView>
        <VerticalStackLayout Padding="25" Spacing="25">

            <!-- Header -->
            <Label Text="Clearance Window"
                   FontSize="28"
                   FontFamily="PoppinsBold"
                   TextColor="#26A69A"
                   HorizontalOptions="Center"
                   Margin="0,20,0,10"/>

            <!-- Clearance Entry Section -->
            <Frame BackgroundColor="White" Padding="20" CornerRadius="12" HasShadow="True">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Clear Menu Item"
                           FontSize="20"
                           FontFamily="PoppinsBold"
                           TextColor="#212121"/>

                    <!-- Searchable Picker -->
                    <SearchBar x:Name="MenuItemSearchBar"
                               Placeholder="Search menu item..."
                               TextChanged="MenuItemSearchBar_TextChanged"/>

                    <CollectionView x:Name="MenuItemResultsCollection"
                                    HeightRequest="120"
                                    SelectionMode="Single"
                                     IsVisible="False"
                                    SelectionChanged="MenuItemResultsCollection_SelectionChanged">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Padding="10"
                                       Margin="2"
                                       BackgroundColor="#E0F2F1"
                                       CornerRadius="8">
                                    <Label Text="{Binding Name}" FontFamily="PoppinsRegular"/>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Quantity -->
                    <Entry x:Name="QuantityEntry"
                           Placeholder="Enter quantity to clear"
                           Keyboard="Numeric"/>

                    <!-- Reason -->
                    <Entry x:Name="ReasonEntry"
                           Placeholder="Reason (e.g., Damaged, Stale)"/>

                    <!-- Optional Note -->
                    <Editor x:Name="NoteEditor"
                            Placeholder="Optional note"
                            AutoSize="TextChanges"
                            HeightRequest="80"/>

                    <!-- Submit Button -->
                    <Button Text="Submit Clearance"
                            BackgroundColor="#26A69A"
                            TextColor="White"
                            FontFamily="PoppinsRegular"
                            CornerRadius="10"
                            Clicked="SubmitClearance_Clicked"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Clearance List -->
            <Frame BackgroundColor="White" Padding="15" CornerRadius="12" HasShadow="True">
                <VerticalStackLayout>
                    <Label Text="Today's Clearances"
                           FontSize="20"
                           FontFamily="PoppinsBold"
                           TextColor="#212121"
                           Margin="0,0,0,10"/>

                    <CollectionView x:Name="ClearanceCollectionView"
                                    HeightRequest="300">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Padding="10"
                                       Margin="0,5"
                                       BackgroundColor="#E0F2F1"
                                       CornerRadius="8">
                                    <Grid ColumnDefinitions="2*,1*,1*" ColumnSpacing="10">

                                        <!-- Item Name -->
                                        <Label Text="{Binding ItemName}"
                                               FontFamily="PoppinsBold"
                                               TextColor="#004D40"
                                               VerticalOptions="Center"
                                               Grid.Column="0"/>

                                        <!-- Quantity -->
                                        <Label Text="{Binding Quantity, StringFormat='Qty: {0}'}"
                                               VerticalOptions="Center"
                                               Grid.Column="1"
                                               HorizontalOptions="Center"/>

                                        <!-- Reason -->
                                        <Label Text="{Binding Reason}"
                                               VerticalOptions="Center"
                                               Grid.Column="2"
                                               HorizontalOptions="End"/>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
